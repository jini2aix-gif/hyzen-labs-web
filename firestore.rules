rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'jini2aix@gmail.com';
    }

    // Gallery (Sole Vision) collection
    match /artifacts/{appId}/public/data/gallery/{docId} {
      allow read, write: if true;
    }

    // Games Scores collection
    match /artifacts/{appId}/public/data/games/{gameId}/scores/{docId} {
      allow read, create: if true;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // Stats
    match /artifacts/{appId}/public/data/stats/{docId} {
      allow read, write: if true;
    }

    // Treasury History
    match /artifacts/{appId}/public/data/treasury_history/{docId} {
      allow read, write: if true;
    }

    // Users (Deprecated)
    match /artifacts/{appId}/public/data/users/{uid} {
      allow read, write: if isAdmin();
    }
  }
}
