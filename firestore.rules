rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'jini2aix@gmail.com';
    }
    // Check if user is in banned collection
    function isBanned(appId, uid) {
      return exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/banned/$(uid));
    }
    function isValidText(text, maxLen) {
      return text is string && text.size() >= 0 && text.size() <= maxLen;
    }

    // global guard removed; relies on specific rules

    // Users collection
    match /artifacts/{appId}/public/data/users/{uid} {
      allow read: if isOwner(uid) || isAdmin() || isAuthenticated();
      allow create: if isOwner(uid) && !isBanned(appId, uid)
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email;
      allow update: if (isOwner(uid) || isAdmin()) && !isBanned(appId, uid)
        && request.resource.data.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    // Banned Collection (Admin Only)
    match /artifacts/{appId}/public/data/banned/{uid} {
      allow read, write: if isAdmin();
    }

    // Posts collection
    match /artifacts/{appId}/public/data/posts/{postId} {
      allow read: if isAuthenticated() && !isBanned(appId, request.auth.uid);
      allow create: if isAuthenticated() && !isBanned(appId, request.auth.uid)
        && request.resource.data.authorId == request.auth.uid
        && isValidText(request.resource.data.title, 200)
        && isValidText(request.resource.data.content, 5000);
      allow update: if isAuthenticated() && !isBanned(appId, request.auth.uid)
        && resource.data.authorId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid || isAdmin()
      );
    }

    // Comments sub-collection
    match /artifacts/{appId}/public/data/posts/{postId}/comments/{cid} {
      allow read: if isAuthenticated() && !isBanned(appId, request.auth.uid);
      allow create: if isAuthenticated() && !isBanned(appId, request.auth.uid)
        && request.resource.data.authorId == request.auth.uid
        && isValidText(request.resource.data.text, 1000);
      allow update: if isAuthenticated() && !isBanned(appId, request.auth.uid)
        && resource.data.authorId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid || isAdmin()
      );
    }

    // HNRC Posts collection
    match /artifacts/{appId}/public/data/hnrc_posts/{postId} {
      allow read: if isAuthenticated() && !isBanned(appId, request.auth.uid);
      allow create: if isAuthenticated() && !isBanned(appId, request.auth.uid)
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && !isBanned(appId, request.auth.uid);
      allow delete: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid || isAdmin()
      );
    }
    
    // HNRC Posts Comments sub-collection
    match /artifacts/{appId}/public/data/hnrc_posts/{postId}/comments/{cid} {
      allow read: if isAuthenticated() && !isBanned(appId, request.auth.uid);
      allow create: if isAuthenticated() && !isBanned(appId, request.auth.uid)
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && !isBanned(appId, request.auth.uid);
      allow delete: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid || isAdmin()
      );
    }

    // Games Scores collection
    match /artifacts/{appId}/public/data/games/{gameId}/scores/{docId} {
      allow read: if true;
      allow create: if isAuthenticated() && !isBanned(appId, request.auth.uid)
        && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // Stats
    match /artifacts/{appId}/public/data/stats/{docId} {
      allow read: if true;
      allow update: if isAdmin() ||
        (!isBanned(appId, request.auth.uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visitorCount'])
         && request.resource.data.visitorCount == resource.data.visitorCount + 1);
      allow create: if isAdmin() ||
        (request.resource.data.keys().hasOnly(['visitorCount'])
         && request.resource.data.visitorCount == 1);
    }
  }
}
